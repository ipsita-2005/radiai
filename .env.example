# Frontend Environment Variables

# ============================================
# OPTION 1: Use Gemini AI (RECOMMENDED for Vercel)
# ============================================

# Get your FREE API key from: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_api_key_here

# Gemini model to use (optional, defaults to gemini-1.5-flash)
# VITE_GEMINI_MODEL=gemini-1.5-flash

# ============================================
# OPTION 2: Demo Mode (No API Key Required)
# ============================================

# Leave VITE_GEMINI_API_KEY empty or unset to use mock data
# The app will automatically fall back to demo mode

# ============================================
# HOW IT WORKS:
# ============================================
# - With API key: Real AI analysis using Google Gemini
# - Without API key: Mock/demo analysis results
# - Both modes work perfectly on Vercel!
# ============================================
